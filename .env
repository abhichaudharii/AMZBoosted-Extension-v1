# AMZBoosted Extension - Development Environment
# PRIVATE REPOSITORY - Local development configuration

# API Configuration (Production)
VITE_API_URL=https://amzboosted.com/api/v1
VITE_DASHBOARD_URL=https://amzboosted.com

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_DEBUG_LOGGING=false

# Extension Configuration
VITE_EXTENSION_VERSION=1.0.0
VITE_MIN_CHROME_VERSION=120

# Rate Limiting
VITE_MAX_REQUESTS_PER_MINUTE=60
VITE_REQUEST_TIMEOUT=30000

# Cache Configuration
VITE_CACHE_TTL=300000
VITE_MAX_CACHE_SIZE=10485760

# Security
VITE_ENABLE_CSP=true
VITE_ENABLE_HTTPS_ONLY=true

# Development
NODE_ENV=production
